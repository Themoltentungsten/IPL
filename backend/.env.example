PORT=3001

# Real-time scores: free API key from https://cricketdata.org/ (CricAPI)
CRICAPI_API_KEY=
# IPL 2026 series ID (auto-detected — change only if needed)
IPL_SERIES_ID=87c62aac-bc3c-4738-ab93-19da0690488f
# Poll interval in ms (default 15000). Respect provider rate limits on free tier.
CRICAPI_POLL_MS=15000
# If true (default), prefer IPL-titled matches when filtering currentMatches.
IPL_ONLY_FILTER=true

REDIS_URL=redis://localhost:6379
ML_SERVICE_URL=http://localhost:8000
